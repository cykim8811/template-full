# Backend URL used by Next.js rewrites (server-side only — NOT bundled into client JS).
# Dev:  http://localhost:8000  (direct to backend)
# Prod (Docker Compose): http://backend:8000  (internal Docker DNS, set in compose.yaml)
# Prod (K8s): http://backend-service:8000
BACKEND_URL=http://localhost:8000

# Must match backend SECRET_KEY exactly — used by middleware for JWT verification.
SECRET_KEY=change-me-in-production

# Set to "true" to show the Google OAuth login button.
NEXT_PUBLIC_GOOGLE_ENABLED=false
